# mailcow-rest-api-webmail operator notes.
#
# The built webmail is static. These values are not read by the browser at
# runtime; they are here so deployment templates and setup notes have one
# place to document the expected public URLs.

WEBMAIL_ORIGIN=https://webmail.example.com
API_ORIGIN=https://mail.example.com/mailcow-rest-api

# Optional AI privacy layer. Put shared model/provider keys in LiteLLM or an
# equivalent OpenAI-compatible proxy, then point mailcow-rest-api at that proxy.
LITELLM_BASE_URL=https://llm.example.com/v1
LITELLM_MODEL=deepseek-v4-flash
